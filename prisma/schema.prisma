generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  WORKER
  CUSTOMER
  ADMIN
  MODERATOR
}

enum WorkerAvailabilityStatus {
  AVAILABLE
  BUSY
  INACTIVE
}

enum CustomerTrustStatus {
  NEW
  VERIFIED
  TRUSTED
  BLOCKED
}

enum JobStatus {
  DRAFT
  ACTIVE
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum JobResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVIEW
}

enum ReviewTargetType {
  WORKER
  CUSTOMER
  JOB
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ModerationEntityType {
  JOB
  JOB_RESPONSE
  REVIEW
  AD
  USER
}

enum ModerationQueueStatus {
  PENDING
  PENDING_MODERATION
  IN_REVIEW
  APPROVED
  REJECTED
}

model User {
  id                String            @id @default(cuid())
  telegramId        String            @unique
  username          String?           @unique
  firstName         String?
  lastName          String?
  phone             String?
  country           String?
  city              String?
  role              UserRole          @default(USER)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workerProfile     WorkerProfile?
  customerProfile   CustomerProfile?
  jobs              Job[]             @relation("CustomerJobs")
  jobResponses      JobResponse[]
  reviewsWritten    Review[]          @relation("ReviewAuthor")
  moderationEntries ModerationQueue[] @relation("ModeratorAssignments")
}

model WorkerProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  bio                   String?
  skills                String?
  rating                Float                    @default(0)
  completedJobsCount    Int                      @default(0)
  dailyResponseLimit    Int                      @default(10)
  availabilityStatus    WorkerAvailabilityStatus @default(AVAILABLE)
  isVerified            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobResponses          JobResponse[]
  selectedForJobs       Job[]                    @relation("SelectedWorker")
  workerReviewsReceived Review[]                 @relation("WorkerReviewTarget")
  ads                   Ad[]
}

model CustomerProfile {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  trustStatus             CustomerTrustStatus @default(NEW)
  completedJobsCount      Int                 @default(0)
  canceledJobsCount       Int                 @default(0)
  totalSpent              Decimal             @default(0)
  isIdentityVerified      Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewsReceived         Review[]            @relation("CustomerReviewTarget")
}

model Job {
  id                      String           @id @default(cuid())
  customerId              String
  title                   String
  description             String
  budget                  Decimal?
  currency                String?          @default("RUB")
  status                  JobStatus        @default(DRAFT)
  moderationStatus        ModerationStatus @default(PENDING)
  locationId              String?
  selectedWorkerProfileId String?
  startsAt                DateTime?
  completedAt             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  customer                User             @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  location                Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  selectedWorker          WorkerProfile?   @relation("SelectedWorker", fields: [selectedWorkerProfileId], references: [id], onDelete: SetNull)
  responses               JobResponse[]
  reviews                 Review[]         @relation("JobReviewTarget")
}

model JobResponse {
  id                String           @id @default(cuid())
  jobId             String
  workerProfileId   String
  userId            String
  message           String?
  proposedPrice     Decimal?
  status            JobResponseStatus @default(PENDING)
  moderationStatus  ModerationStatus  @default(PENDING)
  respondedAt       DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  job               Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerProfile     WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerProfileId])
}

model Review {
  id                String           @id @default(cuid())
  authorId          String
  jobId             String?
  workerProfileId   String?
  customerProfileId String?
  targetType        ReviewTargetType
  rating            Int
  comment           String?
  moderationStatus  ModerationStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  author            User             @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  job               Job?             @relation("JobReviewTarget", fields: [jobId], references: [id], onDelete: SetNull)
  workerProfile     WorkerProfile?   @relation("WorkerReviewTarget", fields: [workerProfileId], references: [id], onDelete: SetNull)
  customerProfile   CustomerProfile? @relation("CustomerReviewTarget", fields: [customerProfileId], references: [id], onDelete: SetNull)
}

model Ad {
  id                String           @id @default(cuid())
  workerProfileId   String
  title             String
  description       String
  priceFrom         Decimal?
  currency          String?          @default("RUB")
  status            AdStatus         @default(DRAFT)
  moderationStatus  ModerationStatus @default(PENDING)
  locationId        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workerProfile     WorkerProfile    @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  location          Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
}

model Location {
  id          String   @id @default(cuid())
  country     String
  city        String
  addressLine String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
  ads         Ad[]
}

model ModerationQueue {
  id             String                @id @default(cuid())
  entityType     ModerationEntityType
  entityId       String
  status         ModerationQueueStatus @default(PENDING)
  reason         String?
  payload        Json?
  assignedToId   String?
  reviewedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  assignedTo     User?                 @relation("ModeratorAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([status])
}
